JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=your-repository-slug
# With Atlassian API tokens (ATATT...), use your Atlassian account email here.
# App passwords still use your Bitbucket username instead.
BITBUCKET_API_USER=your-atlassian-account-email
BITBUCKET_API_TOKEN=your-bitbucket-api-token-or-app-password
# Legacy aliases still supported by the server:
# BITBUCKET_USERNAME=your-bitbucket-username
# BITBUCKET_APP_PASSWORD=your-bitbucket-app-password
SERVER_PORT=3000
CLIENT_ORIGIN=http://localhost:5173
# Optional: Codex worker on laptop via SSH tunnel (see tools/codex-worker/README.md)
# CODEX_WORKER_URL=http://127.0.0.1:9876
# CODEX_WORKER_TOKEN=generate-a-long-random-secret
# Optional (laptop worker only): model for `codex exec -m` (omit to use CLI default)
# CODEX_MODEL=gpt-5.5
# Optional: Discord webhooks for manual notifications (single-line JSON array)
# DISCORD_CHANNELS=[{"id":"dev-general","name":"dev-general","webhookUrl":"https://discord.com/api/webhooks/..."},{"id":"dev-hobbit","name":"dev-hobbit","webhookUrl":"https://discord.com/api/webhooks/..."}]

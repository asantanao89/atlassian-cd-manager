JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=your-repository-slug
BITBUCKET_API_USER=your-bitbucket-username-or-email
BITBUCKET_API_TOKEN=your-bitbucket-app-password
# Legacy aliases still supported by the server:
# BITBUCKET_USERNAME=your-bitbucket-username
# BITBUCKET_APP_PASSWORD=your-bitbucket-app-password
SERVER_PORT=3000
CLIENT_ORIGIN=http://localhost:5173
# Optional: Discord webhooks for manual notifications (single-line JSON array)
# DISCORD_CHANNELS=[{"id":"dev-general","name":"dev-general","webhookUrl":"https://discord.com/api/webhooks/..."},{"id":"dev-hobbit","name":"dev-hobbit","webhookUrl":"https://discord.com/api/webhooks/..."}]
